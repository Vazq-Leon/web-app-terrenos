# ─── Base de datos ────────────────────────────────────────────────────────────
# URL de conexión PostgreSQL (Render la proporciona automáticamente)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET_KEY=cambia-esta-clave-super-secreta-en-produccion

# ─── Admin por defecto ────────────────────────────────────────────────────────
# Credenciales del administrador creado automáticamente al iniciar la app
# (solo aplica si no existe ningún admin en la base de datos)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=MiContraseñaSegura!2024
